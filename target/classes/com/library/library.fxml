<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<TabPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
         prefHeight="500.0" prefWidth="800.0" tabClosingPolicy="UNAVAILABLE"
         style="-fx-background-color: #F5F5F5;"
         xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.library.controllers.MainController">

  <tabs>

    <!-- ===== НОМЫН БҮРТГЭЛ ===== -->
    <Tab text="Номын бүртгэл">
      <content>
        <AnchorPane style="-fx-background-color: #F5F5F5;">
          <children>
            <SplitPane dividerPositions="0.3" prefHeight="472.0" prefWidth="800.0"
                       style="-fx-background-color: #F5F5F5;">
              <items>
                <AnchorPane style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;">
                  <children>
                    <VBox spacing="8.0" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
                          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
                      <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                      <children>
                        <Label text="Номын бүртгэл" style="-fx-text-fill: #1565C0;">
                          <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label text="Номын нэр" style="-fx-text-fill: #555555;" />
                        <TextField fx:id="txtBookName" promptText="Номын нэр оруулна уу"
                                   style="-fx-border-color: #BBDEFB; -fx-border-radius: 4; -fx-background-radius: 4;" />
                        <Label text="Зохиогч" style="-fx-text-fill: #555555;" />
                        <TextField fx:id="txtAuthor" promptText="Зохиогч оруулна уу"
                                   style="-fx-border-color: #BBDEFB; -fx-border-radius: 4; -fx-background-radius: 4;" />
                        <Label text="ISBN" style="-fx-text-fill: #555555;" />
                        <TextField fx:id="txtIsbn" promptText="ISBN оруулна уу"
                                   style="-fx-border-color: #BBDEFB; -fx-border-radius: 4; -fx-background-radius: 4;" />
                        <Label text="Тоо ширхэг" style="-fx-text-fill: #555555;" />
                        <TextField fx:id="txtQty" promptText="Тоо оруулна уу"
                                   style="-fx-border-color: #BBDEFB; -fx-border-radius: 4; -fx-background-radius: 4;" />
                        <HBox spacing="8.0">
                          <VBox.margin><Insets top="10.0" /></VBox.margin>
                          <children>
                            <Button fx:id="btnAddBook" text="Нэмэх" onAction="#onAddBookClick"
                                    style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;">
                              <font><Font name="System Bold" size="12.0" /></font>
                            </Button>
                            <Button text="Засах" onAction="#onZasahButton"
                                    style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;">
                              <font><Font name="System Bold" size="12.0" /></font>
                            </Button>
                            <Button text="Устгах" onAction="#btnDelete"
                                    style="-fx-background-color: #D32F2F; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;">
                              <font><Font name="System Bold" size="12.0" /></font>
                            </Button>
                          </children>
                        </HBox>
                      </children>
                    </VBox>
                  </children>
                </AnchorPane>

                <AnchorPane style="-fx-background-color: #FFFFFF;">
                  <children>
                    <VBox spacing="10.0" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
                          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
                      <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                      <children>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                          <children>
                            <Label text="Хайх:" style="-fx-text-fill: #555555;">
                              <font><Font name="System Bold" size="12.0" /></font>
                            </Label>
                            <TextField fx:id="txtBookResearch" promptText="Хайх үг оруулна уу..."
                                       HBox.hgrow="ALWAYS" prefHeight="30.0"
                                       style="-fx-border-color: #BBDEFB; -fx-border-radius: 4; -fx-background-radius: 4;" />
                          </children>
                        </HBox>
                        <TableView fx:id="tableBook" VBox.vgrow="ALWAYS"
                                   style="-fx-border-color: #E0E0E0;">
                          <columns>
                            <TableColumn fx:id="colId" prefWidth="48.0" text="ID" />
                            <TableColumn fx:id="colTitle" prefWidth="154.0" text="Номын нэр" />
                            <TableColumn fx:id="colAuthor" prefWidth="100.0" text="Зохиолч" />
                            <TableColumn fx:id="colIsbn" prefWidth="80.0" text="ISBN" />
                            <TableColumn fx:id="colQty" prefWidth="80.0" text="Үлдэгдэл" />
                            <TableColumn fx:id="colAv" prefWidth="104.0" text="Боломжит үлдэгдэл" />
                          </columns>
                        </TableView>
                      </children>
                    </VBox>
                  </children>
                </AnchorPane>
              </items>
            </SplitPane>
          </children>
        </AnchorPane>
      </content>
    </Tab>

    <!-- ===== УНШИГЧИЙН БҮРТГЭЛ ===== -->
    <Tab text="Уншигчийн бүртгэл">
      <content>
        <AnchorPane style="-fx-background-color: #F5F5F5;">
          <children>
            <SplitPane dividerPositions="0.3" prefHeight="470.0" prefWidth="800.0"
                       style="-fx-background-color: #F5F5F5;">
              <items>
                <AnchorPane style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;">
                  <children>
                    <VBox spacing="8.0" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
                          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
                      <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                      <children>
                        <Label text="Уншигчийн бүртгэл" style="-fx-text-fill: #1565C0;">
                          <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label text="Нэр" style="-fx-text-fill: #555555;" />
                        <TextField fx:id="txtMemberName" promptText="Нэр оруулна уу"
                                   style="-fx-border-color: #BBDEFB; -fx-border-radius: 4; -fx-background-radius: 4;" />
                        <Label text="Овог" style="-fx-text-fill: #555555;" />
                        <TextField fx:id="txtSurname" promptText="Овог оруулна уу"
                                   style="-fx-border-color: #BBDEFB; -fx-border-radius: 4; -fx-background-radius: 4;" />
                        <Label text="Утас" style="-fx-text-fill: #555555;" />
                        <TextField fx:id="txtPhone" promptText="Утасны дугаар оруулна уу"
                                   style="-fx-border-color: #BBDEFB; -fx-border-radius: 4; -fx-background-radius: 4;" />
                        <Label text="Email" style="-fx-text-fill: #555555;" />
                        <TextField fx:id="txtEmail" promptText="Email оруулна уу"
                                   style="-fx-border-color: #BBDEFB; -fx-border-radius: 4; -fx-background-radius: 4;" />
                        <HBox spacing="8.0">
                          <VBox.margin><Insets top="10.0" /></VBox.margin>
                          <children>
                            <Button text="Нэмэх" onAction="#btnAddMember"
                                    style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;">
                              <font><Font name="System Bold" size="12.0" /></font>
                            </Button>
                            <Button text="Засах" onAction="#btnZasahMember"
                                    style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;">
                              <font><Font name="System Bold" size="12.0" /></font>
                            </Button>
                            <Button text="Хасах" onAction="#btnDeleteMember"
                                    style="-fx-background-color: #D32F2F; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;">
                              <font><Font name="System Bold" size="12.0" /></font>
                            </Button>
                          </children>
                        </HBox>
                      </children>
                    </VBox>
                  </children>
                </AnchorPane>

                <AnchorPane style="-fx-background-color: #FFFFFF;">
                  <children>
                    <VBox spacing="10.0" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
                          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
                      <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                      <children>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                          <children>
                            <Label text="Хайх:" style="-fx-text-fill: #555555;">
                              <font><Font name="System Bold" size="12.0" /></font>
                            </Label>
                            <TextField fx:id="txtMemberSearch" promptText="Хайх үг оруулна уу..."
                                       HBox.hgrow="ALWAYS" prefHeight="30.0"
                                       style="-fx-border-color: #BBDEFB; -fx-border-radius: 4; -fx-background-radius: 4;" />
                          </children>
                        </HBox>
                        <TableView fx:id="tableMember" VBox.vgrow="ALWAYS"
                                   style="-fx-border-color: #E0E0E0;">
                          <columns>
                            <TableColumn fx:id="colMId" prefWidth="38.0" text="ID" />
                            <TableColumn fx:id="colMemberName" prefWidth="141.0" text="Нэр" />
                            <TableColumn fx:id="colMemberSurname" prefWidth="108.0" text="Овог" />
                            <TableColumn fx:id="colPhone" prefWidth="121.0" text="Утас" />
                            <TableColumn fx:id="colEmail" prefWidth="116.0" text="Email" />
                          </columns>
                        </TableView>
                      </children>
                    </VBox>
                  </children>
                </AnchorPane>
              </items>
            </SplitPane>
          </children>
        </AnchorPane>
      </content>
    </Tab>

    <!-- ===== НОМЫН ТҮРЭЭС ===== -->
    <Tab text="Номын түрээс">
      <content>
        <AnchorPane style="-fx-background-color: #F5F5F5;">
          <children>
            <VBox spacing="10.0"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
                  style="-fx-background-color: #FFFFFF;">
              <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
              <children>

                <Label text="Номын түрээс" style="-fx-text-fill: #1565C0;">
                  <font><Font name="System Bold" size="14.0" /></font>
                </Label>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                  <padding><Insets bottom="5.0" top="5.0" /></padding>
                  <children>
                    <Button fx:id="btnRentBook" text="Түрээслэх" onAction="#onRentBookClick"
                            style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;">
                      <font><Font name="System Bold" size="12.0" /></font>
                    </Button>
                    <Button fx:id="btnReturnBook" text="Буцаах" onAction="#onReturnBookClick"
                            style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;">
                      <font><Font name="System Bold" size="12.0" /></font>
                    </Button>
                    <Button text="Засах" onAction="#onEditRentalClick"
                            style="-fx-background-color: #F57C00; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;">
                      <font><Font name="System Bold" size="12.0" /></font>
                    </Button>
                    <RadioButton fx:id="radioAll" text="Бүгд" selected="true"
                                 style="-fx-text-fill: #333333;">
                      <HBox.margin><Insets left="15.0" /></HBox.margin>
                      <toggleGroup><ToggleGroup fx:id="filterGroup" /></toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="radioOverdue" text="Хугацаа хэтэрсэн"
                                 toggleGroup="$filterGroup"
                                 style="-fx-text-fill: #D32F2F;" />
                  </children>
                </HBox>

                <TableView fx:id="tableRental" VBox.vgrow="ALWAYS"
                           style="-fx-border-color: #E0E0E0;">
                  <columns>
                    <TableColumn fx:id="colRentalId" prefWidth="50.0" text="ID" />
                    <TableColumn fx:id="colRentMemberName" prefWidth="150.0" text="Уншигчийн нэр" />
                    <TableColumn fx:id="colRentBookTitle" prefWidth="150.0" text="Номын нэр" />
                    <TableColumn fx:id="colRentDate" prefWidth="146.0" text="Түрээслэсэн өдөр" />
                    <TableColumn fx:id="colReturnDate" prefWidth="136.0" text="Буцаах өдөр" />
                    <TableColumn fx:id="colRentalStatus" prefWidth="135.0" text="Төлөв" />
                  </columns>
                </TableView>

              </children>
            </VBox>
          </children>
        </AnchorPane>
      </content>
    </Tab>

  </tabs>
</TabPane>
